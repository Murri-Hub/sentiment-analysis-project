pipeline {
    agent any

    environment {
        IMAGE_NAME     = "sentiment-analysis-api"
        IMAGE_TAG      = "${env.BUILD_NUMBER}"
        CONTAINER_NAME = "sentiment-api"
        APP_PORT       = "8000"
        REGISTRY       = ""   // e.g. "myregistry.azurecr.io/" — leave empty for local
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout') {
            steps {
                echo "📥 Checking out source code..."
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "📦 Installing Python dependencies..."
                bat """
                    python -m pip install --upgrade pip
                    pip install -r app\\requirements.txt
                """
            }
        }

        stage('Unit & Integration Tests') {
            steps {
                echo "🧪 Running tests..."
                bat """
                    python -m pytest tests/ -v --tb=short --junitxml=test-results.xml
                """
            }
            post {
                always {
                    junit 'test-results.xml'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "🐳 Building Docker image ${IMAGE_NAME}:${IMAGE_TAG}..."
                bat """
                    docker build -t ${REGISTRY}${IMAGE_NAME}:${IMAGE_TAG} app\\
                    docker tag  ${REGISTRY}${IMAGE_NAME}:${IMAGE_TAG} ${REGISTRY}${IMAGE_NAME}:latest
                """
            }
        }

        stage('Push to Registry') {
            when {
                // Only push when building from main/master branch
                anyOf {
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                echo "📤 Pushing image to registry..."
                withCredentials([usernamePassword(
                    credentialsId: 'docker-registry-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    bat """
                        docker login -u %DOCKER_USER% -p %DOCKER_PASS% ${REGISTRY}
                        docker push ${REGISTRY}${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${REGISTRY}${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                echo "🚀 Deploying container..."
                bat """
                    docker stop ${CONTAINER_NAME} 2>NUL || echo "No running container to stop."
                    docker rm   ${CONTAINER_NAME} 2>NUL || echo "No container to remove."
                    docker run -d ^
                        --name ${CONTAINER_NAME} ^
                        -p ${APP_PORT}:8000 ^
                        --restart unless-stopped ^
                        ${REGISTRY}${IMAGE_NAME}:latest
                """
            }
        }

        stage('Smoke Test') {
            steps {
                echo "💨 Running smoke test against deployed container..."
                // Give the container a moment to start
                bat "ping -n 10 127.0.0.1 > NUL"
                bat """
                    python -c "import urllib.request, json; \
                        req = urllib.request.Request('http://localhost:${APP_PORT}/predict', \
                            data=json.dumps({'review':'Great product!'}).encode(), \
                            headers={'Content-Type':'application/json'}, method='POST'); \
                        res = urllib.request.urlopen(req); \
                        data = json.loads(res.read()); \
                        assert 'sentiment' in data, 'Missing sentiment field'; \
                        print('Smoke test passed:', data)"
                """
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline completed successfully — build #${env.BUILD_NUMBER}"
            // Uncomment and configure to send email notifications:
            // mail to: 'team@company.com',
            //      subject: "✅ Build #${env.BUILD_NUMBER} SUCCESS — ${env.JOB_NAME}",
            //      body: "The pipeline completed successfully.\n\nSee: ${env.BUILD_URL}"
        }
        failure {
            echo "❌ Pipeline FAILED — build #${env.BUILD_NUMBER}"
            // mail to: 'team@company.com',
            //      subject: "❌ Build #${env.BUILD_NUMBER} FAILED — ${env.JOB_NAME}",
            //      body: "The pipeline failed.\n\nSee: ${env.BUILD_URL}"
        }
        always {
            echo "🧹 Cleaning up dangling Docker images..."
            bat "docker image prune -f"
        }
    }
}
